# Copy to .env (gitignored) or export these in your shell.
# Local dev database = Postgres running in Docker (see README/build steps).
# The +psycopg suffix tells SQLAlchemy to use the psycopg 3 driver.
DATABASE_URL=postgresql+psycopg://postgres:dev@localhost:5432/releasepulse

# Bearer token required on every mutating API call. Use a real random value
# outside local dev; this placeholder is fine for the local Docker setup.
ADMIN_TOKEN=dev-admin-token

# 'production' (default) rejects all non-globally-routable URLs.
# 'dev' also allows the hosts/CIDRs in SSRF_ALLOWLIST (for the Compose demo).
APP_ENV=dev
SSRF_ALLOWLIST=
